rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function email() {
      return lower(request.auth.token.email);
    }

    function lower(v) {
      return v is string ? v.lower() : '';
    }

    function isBootstrapAdmin() {
      return signedIn() && email() in ['aikhainorth@gmail.com'];
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid));
    }

    function isAdmin() {
      return signedIn() && (
        isBootstrapAdmin() ||
        (
          userDoc(request.auth.uid).data.role == 'admin' &&
          userDoc(request.auth.uid).data.approved == true
        )
      );
    }

    function isApproved() {
      return signedIn() && (
        isBootstrapAdmin() ||
        userDoc(request.auth.uid).data.approved == true
      );
    }

    function userOwns(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    match /users/{uid} {
      allow read: if userOwns(uid) || isAdmin();

      allow create: if userOwns(uid) &&
        request.resource.data.email == email() &&
        request.resource.data.displayName is string &&
        request.resource.data.photoURL is string &&
        request.resource.data.lastLoginAt == request.time &&
        request.resource.data.updatedAt == request.time &&
        request.resource.data.createdAt == request.time &&
        (
          (
            !isBootstrapAdmin() &&
            request.resource.data.approved == false &&
            request.resource.data.role == 'user'
          ) ||
          (
            isBootstrapAdmin() &&
            request.resource.data.approved == true &&
            request.resource.data.role == 'admin'
          )
        );

      allow update: if
        (
          userOwns(uid) &&
          request.resource.data.email == resource.data.email &&
          request.resource.data.role == resource.data.role &&
          request.resource.data.approved == resource.data.approved
        ) || isAdmin();

      allow delete: if false;
    }

    match /promptHistory/{docId} {
      allow read: if signedIn() && (resource.data.uid == request.auth.uid || isAdmin());

      allow create: if isApproved() &&
        request.resource.data.uid == request.auth.uid &&
        request.resource.data.email == email() &&
        request.resource.data.product is string &&
        request.resource.data.location is string &&
        request.resource.data.view is string &&
        request.resource.data.sceneCount is int &&
        request.resource.data.duration is int &&
        request.resource.data.imagePrompt is string &&
        request.resource.data.videoPrompt is string;

      allow update: if
        (isApproved() && resource.data.uid == request.auth.uid && request.resource.data.uid == resource.data.uid) ||
        isAdmin();

      allow delete: if isAdmin();
    }
  }
}
